{
  "compilerOptions": {
    // Environment setup & latest features
    // ESNext mantém acesso aos recursos mais novos da linguagem.
    "lib": ["ESNext"],
    "target": "ESNext",

    // Tipos globais do runtime Bun, incluindo fetch e APIs nativas do ambiente.
    "types": ["bun"],

    // ESNext costuma ser mais previsível para libs modernas.
    "module": "ESNext",
    "moduleDetection": "force",

    // Como é uma lib TS, o ideal é não aceitar JS solto no projeto.
    "allowJs": false,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,

    // O Bun/build tool cuida da saída; o TS fica só na análise.
    "noEmit": true,

    // Best practices
    "strict": true,

    // Deixo true por pragmatismo.
    "skipLibCheck": true,

    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Reforços extras de segurança
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "strictBindCallApply": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "useDefineForClassFields": true,

    // Some stricter flags
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": true
  }
}