{
  "name": "pedidook-sdk",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run src/examples/index.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "build:js": "bun build ./src/index.ts --outdir ./dist --format esm",
    "build": "bun run clean && bun run typecheck && bun run build:types && bun run build:js"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2"
  }
}