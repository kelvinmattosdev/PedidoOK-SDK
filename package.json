{
  "name": "pedidook-sdk",
  "version": "1.1.3",
  "description": "SDK TypeScript para integração com a API do PedidoOK",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pedidook",
    "sdk",
    "typescript",
    "api"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kelvinmattosdev/PedidoOK-SDK.git"
  },
  "homepage": "https://github.com/kelvinmattosdev/PedidoOK-SDK#readme",
  "bugs": {
    "url": "https://github.com/kelvinmattosdev/PedidoOK-SDK/issues"
  },
  "scripts": {
    "dev": "bun run src/examples/index.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "build:js": "bun build ./src/index.ts --outdir ./dist --format esm",
    "build": "bun run clean && bun run typecheck && bun run build:types && bun run build:js"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "pedidook-sdk": "."
  }
}
